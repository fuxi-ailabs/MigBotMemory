{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": ".mbm/hooks/on_session_start.sh",
        "timeout": 10
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": ".mbm/hooks/on_stop.sh",
        "timeout": 5
      }
    ],
    "SessionEnd": [
      {
        "type": "command",
        "command": ".mbm/hooks/on_session_end.sh",
        "timeout": 15
      }
    ]
  }
}