{
  "hooks": {
    "PostToolUse": [
      {
        "type": "command",
        "command": ".mbm/hooks/on_skill_use.sh",
        "matcher": "Skill",
        "timeout": 3
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": ".mbm/hooks/on_stop.sh",
        "timeout": 5
      }
    ]
  }
}